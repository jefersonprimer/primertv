generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model Anime {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  aired         String?
  rating        String?
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  seasons       Season[]

  @@index([createdAt])
  @@index([title])
}

model Season {
  id        String    @id @default(cuid())
  number    Int
  animeId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  episodes  Episode[]
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([animeId, number])
  @@index([animeId])
}

model Episode {
  id        String   @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Series {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String         @unique
  description   String?
  imageUrl      String?
  genres        String[]       @default([])
  lastScrapedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  seasons       SeriesSeason[]

  @@index([createdAt])
  @@index([title])
}

model SeriesSeason {
  id        String          @id @default(cuid())
  number    Int
  seriesId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  episodes  SeriesEpisode[]
  series    Series          @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, number])
  @@index([seriesId])
}

model SeriesEpisode {
  id        String       @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  season    SeriesSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Movie {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  videoUrl      String?
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([title])
}

model Manga {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  chapters      Chapter[]

  @@index([createdAt])
  @@index([title])
}

model Chapter {
  id        String   @id @default(cuid())
  number    Float
  title     String?
  pages     String[]
  mangaId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([mangaId, number])
  @@index([mangaId])
  @@index([createdAt])
}

model Novela {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String         @unique
  description   String?
  imageUrl      String?
  genres        String[]       @default([])
  lastScrapedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  seasons       NovelaSeason[]

  @@index([createdAt])
  @@index([title])
}

model NovelaSeason {
  id        String          @id @default(cuid())
  number    Int
  novelaId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  episodes  NovelaEpisode[]
  novela    Novela          @relation(fields: [novelaId], references: [id], onDelete: Cascade)

  @@unique([novelaId, number])
  @@index([novelaId])
}

model NovelaEpisode {
  id        String       @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  season    NovelaSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Channel {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String          @unique
  description   String?
  imageUrl      String?
  videoUrl      String?
  embedUrl      String?
  position      Int             @default(0)
  lastScrapedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sources       ChannelSource[]

  @@index([createdAt])
  @@index([title])
  @@index([position])
}

model ChannelSource {
  id        String   @id @default(cuid())
  title     String
  url       String
  channelId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
}
