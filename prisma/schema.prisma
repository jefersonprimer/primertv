generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

enum WatchlistMediaType {
  ANIME
  MANGA
  SERIES
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  password       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  watchlistItems WatchlistItem[]
  watchHistory   WatchHistory[]
  customLists    CustomList[]
}

model WatchlistItem {
  id        String             @id @default(cuid())
  userId    String
  mediaType WatchlistMediaType
  animeId   String?
  mangaId   String?
  seriesId  String?
  createdAt DateTime           @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime  Anime?  @relation(fields: [animeId], references: [id], onDelete: Cascade)
  manga  Manga?  @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  series Series? @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
  @@unique([userId, mangaId])
  @@unique([userId, seriesId])
  @@index([userId, mediaType, createdAt])
}

model Anime {
  id                String           @id @default(cuid())
  slug              String           @unique
  title             String           @unique
  titleEnglish      String?
  anilistId         Int?             @unique
  malId             Int?             @unique
  description       String?
  imageUrl          String?
  bannerUrl         String?
  logoUrl           String?
  compactImageUrl   String?
  genres            String[]         @default([])
  audio             String[]         @default([])
  subtitles         String[]         @default([])
  awards            String[]         @default([])
  aired             String?
  rating            String?
  score             Float?
  status            String?
  duration          String?
  season            String?
  year              Int?
  broadcastDay      String?
  broadcastTime     String?
  broadcastTimezone String?
  broadcastString   String?
  rank              Int?
  popularity        Int?
  members           Int?
  lastScrapedAt     DateTime?
  latestSeasonId    String?
  latestEpisodeId   String?
  latestEpisodeNumber Int?
  latestEpisodeAt   DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  seasons           Season[]
  watchlistItems    WatchlistItem[]
  customListItems   CustomListItem[]

  @@index([createdAt])
  @@index([bannerUrl, createdAt])
  @@index([status, createdAt])
  @@index([season, year])
  @@index([title])
  @@index([titleEnglish])
  @@index([anilistId])
  @@index([malId])
  @@index([rank])
  @@index([popularity])
  @@index([members])
  @@index([latestEpisodeAt])
  @@index([updatedAt])
}

model Season {
  id        String    @id @default(cuid())
  number    Int
  animeId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  episodes  Episode[]
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([animeId, number])
  @@index([animeId])
}

model Episode {
  id            String         @id @default(cuid())
  number        Int
  title         String?
  slug          String?
  publicId      String?        @unique
  videoUrl      String?
  imageUrl      String?
  customPlayers String[]       @default([])
  seasonId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  season        Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  watchHistory  WatchHistory[]

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  watchedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId, watchedAt])
}

model Series {
  id              String           @id @default(cuid())
  slug            String           @unique
  title           String           @unique
  description     String?
  imageUrl        String?
  bannerUrl       String?
  logoUrl         String?
  genres          String[]         @default([])
  rating          String?
  score           Float?
  year            Int?
  tmdbId          String?
  lastScrapedAt   DateTime?
  latestSeasonId    String?
  latestEpisodeId   String?
  latestEpisodeNumber Int?
  latestEpisodeAt   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  seasons         SeriesSeason[]
  watchlistItems  WatchlistItem[]
  customListItems CustomListItem[]

  @@index([createdAt])
  @@index([bannerUrl, createdAt])
  @@index([score, createdAt])
  @@index([title])
  @@index([latestEpisodeAt])
  @@index([updatedAt])
}

model SeriesSeason {
  id        String          @id @default(cuid())
  number    Int
  seriesId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  episodes  SeriesEpisode[]
  series    Series          @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, number])
  @@index([seriesId])
}

model SeriesEpisode {
  id        String       @id @default(cuid())
  number    Int
  title     String?
  slug      String?
  publicId  String?      @unique
  videoUrl  String?
  seasonId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  season    SeriesSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Movie {
  id            String    @id @default(cuid())
  slug          String    @unique
  publicId      String?   @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  bannerUrl     String?
  logoUrl       String?
  genres        String[]  @default([])
  videoUrl      String?
  rating        String?
  runtime       Int?
  releaseDate   DateTime?
  score         Float?
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tmdbId        String?

  @@index([createdAt])
  @@index([bannerUrl, createdAt])
  @@index([score, createdAt])
  @@index([title])
  @@index([updatedAt])
}

model Manga {
  id             String          @id @default(cuid())
  slug           String          @unique
  title          String          @unique
  description    String?
  imageUrl       String?
  bannerUrl      String?
  genres         String[]        @default([])
  aired          String?
  rating         String?
  status         String?
  lastScrapedAt  DateTime?
  latestChapterId String?
  latestChapterNumber Float?
  latestChapterAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  chapters       Chapter[]
  watchlistItems WatchlistItem[]

  @@index([createdAt])
  @@index([title])
  @@index([latestChapterAt])
  @@index([updatedAt])
}

model Chapter {
  id        String   @id @default(cuid())
  number    Float
  title     String?
  pages     String[]
  mangaId   String
  publicId  String?  @unique
  slug      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([mangaId, number])
  @@index([mangaId])
  @@index([createdAt])
}

model Novela {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String         @unique
  description   String?
  imageUrl      String?
  genres        String[]       @default([])
  latestSeasonId String?
  latestEpisodeId String?
  latestEpisodeNumber Int?
  latestEpisodeAt DateTime?
  lastScrapedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  seasons       NovelaSeason[]

  @@index([createdAt])
  @@index([title])
  @@index([latestEpisodeAt])
  @@index([updatedAt])
}

model NovelaSeason {
  id        String          @id @default(cuid())
  number    Int
  novelaId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  episodes  NovelaEpisode[]
  novela    Novela          @relation(fields: [novelaId], references: [id], onDelete: Cascade)

  @@unique([novelaId, number])
  @@index([novelaId])
}

model NovelaEpisode {
  id        String       @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  season    NovelaSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Channel {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String          @unique
  description   String?
  imageUrl      String?
  videoUrl      String?
  embedUrl      String?
  position      Int             @default(0)
  lastScrapedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sources       ChannelSource[]

  @@index([createdAt])
  @@index([title])
  @@index([position])
}

model ChannelSource {
  id        String   @id @default(cuid())
  title     String
  url       String
  channelId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
}

model CustomList {
  id          String           @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CustomListItem[]

  @@index([userId])
}

model CustomListItem {
  id        String   @id @default(cuid())
  listId    String
  animeId   String?
  seriesId  String?
  createdAt DateTime @default(now())

  list   CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)
  anime  Anime?     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  series Series?    @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([listId, animeId])
  @@unique([listId, seriesId])
  @@index([listId, createdAt])
  @@index([animeId])
  @@index([seriesId])
}
