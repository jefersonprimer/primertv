// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model Anime {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  seasons       Season[]
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([title])
}

model Season {
  id        String    @id @default(cuid())
  number    Int
  animeId   String
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  episodes  Episode[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([animeId, number])
  @@index([animeId])
}

model Episode {
  id        String   @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String? // Can be an iframe url or mp4 link
  seasonId  String
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Series {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  seasons       SeriesSeason[]

  @@index([createdAt])
  @@index([title])
}

model SeriesSeason {
  id        String    @id @default(cuid())
  number    Int
  seriesId  String
  series    Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episodes  SeriesEpisode[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([seriesId, number])
  @@index([seriesId])
}

model SeriesEpisode {
  id        String   @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  season    SeriesSeason   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Movie {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  videoUrl      String?
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([title])
}

model Manga {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  chapters      Chapter[]
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([title])
}

model Chapter {
  id        String   @id @default(cuid())
  number    Float
  title     String?
  pages     String[]
  mangaId   String
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mangaId, number])
  @@index([mangaId])
  @@index([createdAt])
}

model Novela {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  genres        String[]  @default([])
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  seasons       NovelaSeason[]

  @@index([createdAt])
  @@index([title])
}

model NovelaSeason {
  id        String    @id @default(cuid())
  number    Int
  novelaId  String
  novela     Novela    @relation(fields: [novelaId], references: [id], onDelete: Cascade)
  episodes  NovelaEpisode[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([novelaId, number])
  @@index([novelaId])
}

model NovelaEpisode {
  id        String   @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  season    NovelaSeason   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Channel {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  videoUrl      String?
  embedUrl      String?
  sources       ChannelSource[]
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([title])
}

model ChannelSource {
  id        String   @id @default(cuid())
  title     String
  url       String
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId])
}


