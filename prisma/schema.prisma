generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

enum WatchlistMediaType {
  ANIME
  MANGA
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  password       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  watchlistItems WatchlistItem[]
  watchHistory   WatchHistory[]
  customLists    CustomList[]
}

model WatchlistItem {
  id        String             @id @default(cuid())
  userId    String
  mediaType WatchlistMediaType
  animeId   String?
  mangaId   String?
  createdAt DateTime           @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime? @relation(fields: [animeId], references: [id], onDelete: Cascade)
  manga Manga? @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
  @@unique([userId, mangaId])
  @@index([userId])
}

model Anime {
  id              String           @id @default(cuid())
  slug            String           @unique
  title           String           @unique
  description     String?
  imageUrl        String?
  bannerUrl       String?
  genres          String[]         @default([])
  aired           String?
  rating          String?
  status          String?
  duration        String?
  lastScrapedAt   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  seasons         Season[]
  watchlistItems  WatchlistItem[]
  customListItems CustomListItem[]

  @@index([createdAt])
  @@index([title])
}

model Season {
  id        String    @id @default(cuid())
  number    Int
  animeId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  episodes  Episode[]
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([animeId, number])
  @@index([animeId])
}

model Episode {
  id           String         @id @default(cuid())
  number       Int
  title        String?
  videoUrl     String?
  imageUrl     String?
  seasonId     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  season       Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  watchHistory WatchHistory[]

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  watchedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId, watchedAt])
}

model Series {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String         @unique
  description   String?
  imageUrl      String?
  bannerUrl     String?
  genres        String[]       @default([])
  lastScrapedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  seasons       SeriesSeason[]

  @@index([createdAt])
  @@index([title])
}

model SeriesSeason {
  id        String          @id @default(cuid())
  number    Int
  seriesId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  episodes  SeriesEpisode[]
  series    Series          @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, number])
  @@index([seriesId])
}

model SeriesEpisode {
  id        String       @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  season    SeriesSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Movie {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  bannerUrl     String?
  genres        String[]  @default([])
  videoUrl      String?
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([title])
}

model Manga {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String    @unique
  description   String?
  imageUrl      String?
  bannerUrl     String?
  genres        String[]  @default([])
  aired         String?
  rating        String?
  status        String?
  lastScrapedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  chapters       Chapter[]
  watchlistItems WatchlistItem[]

  @@index([createdAt])
  @@index([title])
}

model Chapter {
  id        String   @id @default(cuid())
  number    Float
  title     String?
  pages     String[]
  mangaId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([mangaId, number])
  @@index([mangaId])
  @@index([createdAt])
}

model Novela {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String         @unique
  description   String?
  imageUrl      String?
  genres        String[]       @default([])
  lastScrapedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  seasons       NovelaSeason[]

  @@index([createdAt])
  @@index([title])
}

model NovelaSeason {
  id        String          @id @default(cuid())
  number    Int
  novelaId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  episodes  NovelaEpisode[]
  novela    Novela          @relation(fields: [novelaId], references: [id], onDelete: Cascade)

  @@unique([novelaId, number])
  @@index([novelaId])
}

model NovelaEpisode {
  id        String       @id @default(cuid())
  number    Int
  title     String?
  videoUrl  String?
  seasonId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  season    NovelaSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@index([seasonId])
  @@index([createdAt])
}

model Channel {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String          @unique
  description   String?
  imageUrl      String?
  videoUrl      String?
  embedUrl      String?
  position      Int             @default(0)
  lastScrapedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sources       ChannelSource[]

  @@index([createdAt])
  @@index([title])
  @@index([position])
}

model ChannelSource {
  id        String   @id @default(cuid())
  title     String
  url       String
  channelId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
}

model CustomList {
  id          String           @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CustomListItem[]

  @@index([userId])
}

model CustomListItem {
  id        String     @id @default(cuid())
  listId    String
  animeId   String
  createdAt DateTime   @default(now())

  list  CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)
  anime Anime      @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([listId, animeId])
  @@index([listId])
  @@index([animeId])
}

